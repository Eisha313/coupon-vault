generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Coupon {
  id              String      @id @default(cuid())
  code            String      @unique
  description     String?
  discountType    DiscountType
  discountValue   Float
  minimumPurchase Float?      @default(0)
  maxDiscount     Float?
  usageLimit      Int?
  usageCount      Int         @default(0)
  perUserLimit    Int?        @default(1)
  isActive        Boolean     @default(true)
  startsAt        DateTime?   @default(now())
  expiresAt       DateTime?
  stripeId        String?     @unique
  metadata        Json?
  requiresEmail   Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  redemptions     Redemption[]
  emailCaptures   EmailCapture[]
  claims          CouponClaim[]

  @@index([code])
  @@index([isActive])
  @@index([stripeId])
}

model Redemption {
  id            String   @id @default(cuid())
  couponId      String
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  orderId       String?
  customerId    String?
  customerEmail String?
  orderTotal    Float?
  discountAmount Float?
  stripePaymentId String?
  redeemedAt    DateTime @default(now())
  metadata      Json?

  @@index([couponId])
  @@index([customerId])
  @@index([redeemedAt])
}

model EmailCapture {
  id          String   @id @default(cuid())
  email       String
  couponId    String
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  source      String   @default("share_link")
  ipAddress   String?
  userAgent   String?
  capturedAt  DateTime @default(now())

  @@index([couponId])
  @@index([email])
  @@index([capturedAt])
}

model CouponClaim {
  id          String   @id @default(cuid())
  couponId    String
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  email       String?
  claimToken  String   @unique
  claimedAt   DateTime @default(now())
  redeemedAt  DateTime?

  @@index([couponId])
  @@index([claimToken])
}

enum DiscountType {
  percentage
  fixed
}
